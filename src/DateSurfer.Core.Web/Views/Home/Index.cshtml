@{
    ViewData["Title"] = "DateSurfer - Membership Fee Calculator";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">DateSurfer Membership Fee Calculator</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <strong>Demo:</strong> User ID 1 (Germany, 34 years) | User ID 2 (USA, 25 years)
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">User ID</label>
                        <input type="number" id="userId" class="form-control" value="1" placeholder="Enter user ID">
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Membership Type</label>
                        <select id="membershipType" class="form-select">
                            <option value="0">Basic</option>
                            <option value="1" selected>Premium</option>
                            <option value="2">VIP</option>
                        </select>
                    </div>
                    
                    <button id="calculateBtn" class="btn btn-primary">Calculate Fee</button>
                    
                    <div id="result" class="mt-4" style="display: none;">
                        <div class="alert alert-success">
                            <h4>Monthly Fee: $<span id="feeAmount"></span></h4>
                        </div>
                    </div>
                    
                    <div id="error" class="mt-4" style="display: none;">
                        <div class="alert alert-danger">
                            <span id="errorMessage"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('calculateBtn').addEventListener('click', async function() {
            const userId = document.getElementById('userId').value;
            const membershipType = document.getElementById('membershipType').value;
            
            // Debug: In Console anzeigen
            console.log("UserId:", userId, "Type:", membershipType);
            
            if (!userId || userId === "") {
                alert("Bitte eine User-ID eingeben");
                return;
            }
            
            document.getElementById('result').style.display = 'none';
            document.getElementById('error').style.display = 'none';
            
            try {
                const response = await fetch('/Home/CalculateFee', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        userId: parseInt(userId),
                        membershipType: parseInt(membershipType)
                    })
                });
                
                const data = await response.json();
                console.log("Response:", data);
                
                if (data.success) {
                    document.getElementById('feeAmount').textContent = data.fee;
                    document.getElementById('result').style.display = 'block';
                } else {
                    document.getElementById('errorMessage').textContent = data.error;
                    document.getElementById('error').style.display = 'block';
                }
            } catch (error) {
                console.error("Error:", error);
                document.getElementById('errorMessage').textContent = error.message;
                document.getElementById('error').style.display = 'block';
            }
        });
    </script>
}