@model DateSurfer.Core.Web.Models.HomeViewModel

@{
    ViewData["Title"] = "DateSurfer - Membership Fee Calculator";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">DateSurfer Membership Fee Calculator</h3>
                </div>
                <div class="card-body">
                    
                    <div class="alert alert-info">
                        <strong>Demo Users:</strong><br />
                        @foreach (var user in Model.TestUsers)
                        {
                            <span>ID: @user.Id - @user.Username - @user.Country - @user.Age years</span>
                        
                            <br />
                        }
                    </div>
                    
                    <form method="post" asp-action="CalculateFee">
                        <div class="mb-3">
                            <label class="form-label">User ID</label>
                            <input type="number" name="userId" class="form-control" value="@Model.SelectedUserId" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Membership Type</label>
                            <select name="membershipType" class="form-select">
                                <option value="0">Basic</option>
                                <option value="1" selected>Premium</option>
                                <option value="2">VIP</option>
                            </select>
                        </div>
                        
                        <button type="submit" class="btn btn-primary">Calculate Fee</button>
                    </form>
                    
                    @if (Model.CalculatedFee.HasValue)
                    {
                        <div class="mt-4 alert alert-success">
                            <h4>Monthly Fee: $@Model.CalculatedFee.Value</h4>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="mt-4 alert alert-danger">
                            @Model.ErrorMessage
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>